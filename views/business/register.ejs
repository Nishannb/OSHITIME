<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OSHI TIME</title>
    <link rel="stylesheet" href="/stylesheets/register.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/css/bootstrap.min.css">   
</head>
<body>
    <!---Heading section-->
    <section class="heading-group">
        <div class="brand-name">
            <h2><a href="#">Oshi Time</a> </h2>
        </div>
    </section>
    <!---End of Heading section-->

    <!---SIGN UP COntainer-->
    <section class="sign-up">
        <div class="main-container">
            <aside class="brand-name">
                <h2>Oshi Time <br><span> Track Working Time </span></h2>
            </aside>
            <aside class="sign-up-container">
                <div class="sign-up">
                    <h1>SIGN UP</h1>
                    <h3>Create a new account</h3>
                </div>
                <div class="signUp-inputContainer">
                    <form class="input-boxes" action="/firm/register" method="post">
                        <input type="text" class="input-box" name="username" id="username" placeholder="Business Name" required>
                        <input type="email" class="input-box" name="email" id="email" placeholder="Email Address" required>
                        <input type="text" class="input-box" name="nearestLocation" id="nearest" placeholder="Location: Nearest Station" required>
                        <input type="text" class="input-box" name="phoneNum" id="phone-num" placeholder="Phone Number" required>
                        <input type="text" class="input-box" name="pinCode" id="pinCode" placeholder="4-digit Pin Code" required>
                        <input type="password" class="input-box" name="password" placeholder="Password" required>
                        <input type="password" class="input-box" name="RePassword" placeholder="Re-Confirm Password" required>
                        <button>Sign Up</button>
                    </form>
                </div>
            </aside>
        </div>
    </section>
    <!---End of SIGN UP COntainer-->
    <!---Footer section-->
    <%- include('../partials/footer')  %> 
    <!---End of Footer section-->
</body>
</html>