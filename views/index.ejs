                        <input type="text" placeholder="Workplace Name" name="workplace" required>
                        <input type="text" placeholder="Location: Nearest station" name="workplaceLocation" required>
                        <button class="submit blue-button" value="Submit">Send</button>
                    </form>
                </div>
            </div> -->
            <%- include('./partials/footer') %>
    </section>
    <script src="/javascripts/googlesheet-worplace-refer.js"></script>
</body>
</html>